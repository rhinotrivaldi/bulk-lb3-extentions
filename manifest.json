{
  "manifest_version": 3,
  "name": "Bulk Entry LB3",
  "version": "1.0.2",
  "description": "Bulk entry Limbah B3 Dihasilkan. Buat yang males - males aja",
  "content_scripts": [
    {
      "matches": ["https://plb3.kemenlh.go.id/siraja-2024/lb3/dihasilkan/*"],
      "js": ["js/main.js"],
      "css": ["css/styles.css"]
    }
  ],
